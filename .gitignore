# Version control ignore rules for Smart Parent Calling System (SPCS)

# Entire Frontend Directory (since only backend is uploaded to this repo)
frontend/

# Virtual Environments
backend/venv/
venv/
.venv/
env/

# Python caching & testing
**/__pycache__/
**/*.pyc
backend/.pytest_cache/
.pytest_cache/

# Databases
**/*.db
**/*.db-journal

# Local Environment Credentials
**/.env
backend/.env
**/.env.local
**/.env.production

# OS/IDE files
.DS_Store
Thumbs.db
.vscode/
.idea/
