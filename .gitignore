# Version control ignore rules for Smart Parent Calling System (SPCS)

# Virtual Environments
backend/venv/
venv/
.venv/
env/

# Python caching & testing
**/__pycache__/
**/*.pyc
backend/.pytest_cache/
.pytest_cache/

# Databases
**/*.db
**/*.db-journal

# Local Environment Credentials
**/.env
backend/.env
frontend/.env
**/.env.local
**/.env.production

# Node / Frontend Build
frontend/node_modules/
node_modules/
frontend/dist/
dist/

# OS/IDE files
.DS_Store
Thumbs.db
.vscode/
.idea/
